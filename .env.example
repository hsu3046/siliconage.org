# ─── Google Gemini ───────────────────────────────────────────────────────────
# Used by the BYOK in-app deep-dive and by build-time scripts (cache, embeddings).
# Get a free key at https://ai.google.dev/
VITE_GOOGLE_API_KEY=your_api_key_here

# ─── Supabase (Phase 0+) ─────────────────────────────────────────────────────
# Public values — bundled into the client. Found in Supabase Studio → Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_public_anon_key

# Server-only — used ONLY by scripts/* (seedSupabase, embeddings, BFS). NEVER expose to client.
# Found in Studio → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Supabase Edge Function secrets (set via `supabase secrets set`) ──────────
# These NEVER appear in client bundles — they're listed here for documentation only.
# GEMINI_API_KEY=...              # Phase 3 QA Edge Function (already configured)
# ADMIN_PASSWORD=...              # Phase 5 admin Edge Function password gate
