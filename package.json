{
  "name": "the-silicon-age",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate-cache": "npx tsx scripts/generateCache.ts",
    "i18n:extract": "npx tsx scripts/extract-nodes.ts",
    "i18n:extract-links": "npx tsx scripts/extract-links.ts",
    "i18n:translate": "npx tsx scripts/translate-nodes.ts",
    "i18n:translate-links": "npx tsx scripts/translate-links.ts",
    "i18n:sync": "npm run i18n:extract && npm run i18n:translate",
    "i18n:sync-links": "npm run i18n:extract-links && npm run i18n:translate-links",
    "i18n:extract-events": "npx tsx scripts/extract-events.ts",
    "i18n:translate-events": "npx tsx scripts/translate-events.ts",
    "i18n:sync-events": "npm run i18n:extract-events && npm run i18n:translate-events",
    "i18n:sync-all": "npm run i18n:sync && npm run i18n:sync-links && npm run i18n:sync-events"
  },
  "dependencies": {
    "@formspree/react": "^2.5.1",
    "@google/genai": "^1.30.0",
    "@google/generative-ai": "^0.21.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "d3": "^7.9.0",
    "dotenv": "^16.4.5",
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.26.1",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}